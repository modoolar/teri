<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Chart template -->
    <record id="l10n_rs_chart_template" model="account.chart.template">
        <field name="name">Kontni okvir Republike Srbije</field>
        <field name="code_digits">4</field>
        <field name="bank_account_code_prefix">2410</field>
        <field name="cash_account_code_prefix">2430</field>
        <field name="bank_account_code_prefix_foreign">2440</field>
        <field name="transfer_account_code_prefix">2419</field>
        <field name="currency_id" ref="base.RSD" />
        <field name="complete_tax_set" eval="True" />
        <field name="use_anglo_saxon" eval="True" />
        <field name="country_id" ref="base.rs" />
    </record>
</odoo>
