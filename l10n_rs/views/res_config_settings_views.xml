<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.l10nrs</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="40" />
            <field name="inherit_id" ref="account.res_config_settings_view_form" />
            <field name="arch" type="xml">
                <xpath expr="//div[@data-key='account']" position="inside">
                    <h2
                        attrs="{'invisible':[('country_code', '!=', 'RS')]}"
                    >Accounting Serbia</h2>
                    <div
                        class="row mt16 o_settings_container"
                        name="serbia_localization"
                        attrs="{'invisible':[('country_code', '!=', 'RS')]}"
                    >
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label
                                    string="Default Accounting configuration"
                                    for="service_product_income_account_group_id"
                                />
                                <div class="text-muted">
                                    Configuration for different product types
                                </div>
                                <div class="content-group">
                                    <div class="row mt8">
                                        <label
                                            for="service_product_income_account_group_id"
                                            class="col-lg-3 o_light_label"
                                        />
                                        <field
                                            name="service_product_income_account_group_id"
                                        />
                                    </div>
                                    <div class="row mt8">
                                        <label
                                            for="product_product_income_account_group_id"
                                            class="col-lg-3 o_light_label"
                                        />
                                        <field
                                            name="product_product_income_account_group_id"
                                        />
                                    </div>
                                    <div class="row mt8">
                                        <label
                                            for="down_payment_product_income_account_group_id"
                                            class="col-lg-3 o_light_label"
                                        />
                                        <field
                                            name="down_payment_product_income_account_group_id"
                                        />
                                    </div>
                                    <div class="row mt8">
                                        <label
                                            for="expense_account_group_id"
                                            class="col-lg-3 o_light_label"
                                        />
                                        <field name="expense_account_group_id" />
                                    </div>
                                    <div class="row mt8">
                                        <label
                                            for="account_foreign_payable_id"
                                            class="col-lg-3 o_light_label"
                                        />
                                        <field name="account_foreign_payable_id" />
                                    </div>
                                    <div class="row mt8">
                                        <label
                                            for="account_foreign_receivable_id"
                                            class="col-lg-3 o_light_label"
                                        />
                                        <field name="account_foreign_receivable_id" />
                                    </div>
                                    <div class="row mt8">
                                        <label
                                            for="account_vendor_refund_expense_account_id"
                                            class="col-lg-3 o_light_label"
                                        />
                                        <field
                                            name="account_vendor_refund_expense_account_id"
                                        />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="generate_product_reference" />
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="generate_product_reference" />
                                <div class="text-muted">
                                    Automatically generate product reference
                                </div>
                                <div
                                    class="content-group"
                                    attrs="{'invisible': [('generate_product_reference', '=', False)]}"
                                >
                                    <div class="row mt8">
                                        <label
                                            for="product_sequence_id"
                                            class="col-lg-3 o_light_label"
                                            string="Sequence"
                                        />
                                        <field name="product_sequence_id" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div
                            class="col-12 col-lg-6 o_setting_box"
                            id="l10n_rs_partner_module"
                            title="This will install partner extensions module for serbian localization"
                        >
                            <div class="o_setting_left_pane">
                                <field
                                    name="module_l10n_rs_partner"
                                    widget="upgrade_boolean"
                                />
                            </div>
                            <div class="o_setting_right_pane" id="budget_management">
                                <label for="module_l10n_rs_partner" />
                                <div class="text-muted">
                                    Additional contact and company fields such as Legal Form, VAT status, Bank account status etc.
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
