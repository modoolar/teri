<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_move_form" model="ir.ui.view">
        <field name="name">account.move.form.view</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <field name="invoice_date" position="after">
                <field name="turnover_date" />
                <field name="turnover_place" />
                <field
                    name="reception_date"
                    attrs="{'invisible': [('move_type', 'not in', ('in_invoice', 'in_refund', 'in_receipt'))]}"
                />
                <field name="non_deductable" />
            </field>
            <field name="invoice_payments_widget" position="before">
                <field name="is_company_currency" invisible="True" />
                <field
                    name="company_currency_total"
                    attrs="{'invisible': [('is_company_currency', '=', True)]}"
                />
            </field>
        </field>
    </record>
</odoo>
