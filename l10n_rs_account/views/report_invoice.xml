<odoo>
    <template
        id="l10n_rs_report_invoice_document_inherit"
        inherit_id="account.report_invoice_document"
    >
        <xpath expr="//div[@t-if='o.partner_id.vat']" position="after">
            <div t-if="o.partner_id.company_registry_number" class="mt16">
                Company Registry Number: <span
                    t-field="o.partner_id.company_registry_number"
                />
            </div>
        </xpath>
        <xpath expr="//div[@name='origin']" position="before">
            <div
                class="col-auto col-3 mw-100 mb-2"
                t-if="o.turnover_date"
                name="turnover_date"
            >
                <strong>Turnover Date:</strong>
                <p class="m-0" t-field="o.turnover_date" />
            </div>
            <div
                class="col-auto col-3 mw-100 mb-2"
                t-if="o.turnover_place"
                name="turnover_place"
            >
                <strong>Turnover Place:</strong>
                <p class="m-0" t-field="o.turnover_place" />
            </div>
        </xpath>
        <xpath expr="//t[@t-foreach='payments_vals']//span/.." position="attributes">
            <attribute name="colspan">99</attribute>
        </xpath>
        <xpath expr="//span[@t-field='o.amount_residual']/.." position="attributes">
            <attribute name="colspan">99</attribute>
        </xpath>
        <xpath
            expr="//table[@name='invoice_line_table']//th[@name='th_priceunit']"
            position="after"
        >
            <xpath
                expr="//table[@name='invoice_line_table']//th[@name='th_subtotal']"
                position="move"
            />
        </xpath>
        <xpath
            expr="//table[@name='invoice_line_table']//th[@name='th_taxes']"
            position="after"
        >
            <th name="th_quantity" class="text-right"><span>Total</span></th>
        </xpath>
        <xpath
            expr="//table[@name='invoice_line_table']//span[@t-field='line.price_unit']/.."
            position="after"
        >
            <xpath
                expr="//table[@name='invoice_line_table']//td[hasclass('o_price_total')]"
                position="move"
            />
        </xpath>
        <xpath
            expr="//table[@name='invoice_line_table']//span[@id='line_tax_ids']/.."
            position="after"
        >
            <td class="text-right o_price_total">
                <span class="text-nowrap" t-field="line.price_total" />
            </td>
        </xpath>
        <xpath expr="//p[@name='payment_term']" position="after">
            <t t-set="taxes" t-value="o.invoice_line_ids.mapped('tax_ids')" />
            <t t-foreach="taxes" t-as="tax">
                <span
                    t-field="tax.vat_legislation_mention_id"
                    t-if="tax.vat_legislation_mention_id"
                />
            </t>
        </xpath>
    </template>
    <template id="l10n_rs_document_tax_totals" inherit_id="account.document_tax_totals">
        <xpath
            expr="//span[@t-att-class='oe_subtotal_footer_separator']/.."
            position="attributes"
        >
            <attribute name="colspan">99</attribute>
        </xpath>
        <xpath
            expr="//tr[hasclass('o_total')]/td[hasclass('text-right')]"
            position="attributes"
        >
            <attribute name="colspan">99</attribute>
        </xpath>
        <xpath expr="//tr[hasclass('o_total')]" position="after">
            <t t-if="o">
                <tr
                    class="o_total_company_currency"
                    t-if="o.amount_total != o.company_currency_total"
                >
                    <td />
                    <td class="text-right" colspan="99">
                        <span
                            class="text-nowrap"
                            t-field="o.company_currency_total"
                            t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'
                        />
                    </td>
                </tr>
            </t>
        </xpath>
    </template>
    <template id="l10n_rs_tax_groups_totals" inherit_id="account.tax_groups_totals">
        <xpath expr="//t[@t-as='amount_by_group']" position="replace">
            <tr class="border-black o_subtotal" style="">
                <td><strong>Tax</strong></td>
                <td><strong>Base</strong></td>
                <td class="text-right">
                    <strong>Amount</strong>
                </td>
            </tr>
            <t
                t-foreach="tax_totals['groups_by_subtotal'][subtotal_to_show]"
                t-as="amount_by_group"
            >
                <tr>
                    <td>
                        <span t-esc="amount_by_group['tax_group_name']" />
                    </td>
                    <td>
                        <span
                            t-esc="amount_by_group['formatted_tax_group_base_amount']"
                        />
                    </td>
                    <td class="text-right o_price_total">
                        <span
                            class="text-nowrap"
                            t-esc="amount_by_group['formatted_tax_group_amount']"
                        />
                    </td>
                </tr>
            </t>
        </xpath>
    </template>
</odoo>
