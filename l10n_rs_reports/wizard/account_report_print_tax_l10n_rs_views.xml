<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="account_tax_report_print_l10n_rs_view" model="ir.ui.view">
        <field name="name">account.tax.report.print.l10n.rs.view</field>
        <field name="model">account.print.tax.l10n.rs</field>
        <field name="arch" type="xml">
            <form string="Report Options">
                <group>
                    <group>
                        <label for="date_start" string="Period" />
                        <div class="o_row"><field name="date_start" /> - <field
                                name="date_end"
                            /></div>
                    </group>
                </group>
                <footer>
                    <button
                        name="print_report"
                        string="Print"
                        type="object"
                        default_focus="1"
                        class="oe_highlight"
                    />
                    <button
                        string="Cancel"
                        class="btn btn-secondary"
                        special="cancel"
                    />
                </footer>
            </form>
        </field>
    </record>

</odoo>
